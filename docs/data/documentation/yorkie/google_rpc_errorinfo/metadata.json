{"abstract":[{"type":"text","text":"Additional structured details about this error."}],"sections":[],"variants":[{"paths":["\/documentation\/yorkie\/google_rpc_errorinfo\/metadata"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Yorkie\/documentation\/Yorkie\/Google_Rpc_ErrorInfo\/metadata"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"metadata"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SD","text":"Dictionary"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":">"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Keys must match a regular expression of "},{"type":"codeVoice","code":"[a-z][a-zA-Z0-9-_]+"},{"type":"text","text":" but should"},{"type":"text","text":" "},{"type":"text","text":"ideally be lowerCamelCase. Also, they must be limited to 64 characters in"},{"type":"text","text":" "},{"type":"text","text":"length. When identifying the current value of an exceeded limit, the units"},{"type":"text","text":" "},{"type":"text","text":"should be contained in the key, not the value.  For example, rather than"},{"type":"text","text":" "},{"type":"codeVoice","code":"{\"instanceLimit\": \"100\/request\"}"},{"type":"text","text":", should be returned as,"},{"type":"text","text":" "},{"type":"codeVoice","code":"{\"instanceLimitPerRequest\": \"100\"}"},{"type":"text","text":", if the client exceeds the number of"},{"type":"text","text":" "},{"type":"text","text":"instances that can be created in a single (batch) request."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","metad