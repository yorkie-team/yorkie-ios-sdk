nd":"text"},{"text":"reason","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"abstract":[{"text":"The reason of the error. This is a constant value that identifies the","type":"text"},{"text":" ","type":"text"},{"text":"proximate cause of the error. Error reasons are unique within a particular","type":"text"},{"text":" ","type":"text"},{"text":"domain of errors. This should be at most 63 characters and match a","type":"text"},{"text":" ","type":"text"},{"text":"regular expression of ","type":"text"},{"code":"[A-Z][A-Z0-9_]+[A-Z0-9]","type":"codeVoice"},{"text":", which represents","type":"text"},{"text":" ","type":"text"},{"text":"UPPER_SNAKE_CASE.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/Yorkie\/documentation\/Yorkie\/Google_Rpc_ErrorInfo\/reason","title":"reason"},"doc://Yorkie/documentation/Yorkie/Google_Rpc_ErrorInfo/domain":{"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"domain","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"url":"\/documentation\/yorkie\/google_rpc_errorinfo\/domain","identifier":"doc:\/\/Yorkie\/documentation\/Yorkie\/Google_Rpc_ErrorInfo\/domain","title":"domain","type":"topic","abstract":[{"type":"text","text":"The logical grouping to which the “reason” belongs. The error domain"},{"type":"text","text":" "},{"type":"text","text":"is typically the registered service name of the tool or product that"},{"type":"text","text":" "},{"type":"text","text":"generates the error. Example: “pubsub.googleapis.com”. If the error is"},{"type":"text","text":" "},{"type":"text","text":"generated by some common infrastructure, the error domain must be a"},{"type":"text","text":" "},{"type":"text","text":"globally unique value that identifies the infrastructure. For Google API"},{"type":"text","text":" "},{"type":"text","text":"infrastructure, the error domain is “googleapis.com”."}],"role":"symbol"},"doc://Yorkie/SH":{"title":"Swift.Hashable","identifier":"doc:\/\/Yorkie\/SH","type":"unresolvable"},"doc://Yorkie/documentation/Yorkie":{"abstract":[],"kind":"symbol","title":"Yorkie","url":"\/documentation\/yorkie","role":"collection","identifier":"doc:\/\/Yorkie\/documentation\/Yorkie","type":"topic"}}}