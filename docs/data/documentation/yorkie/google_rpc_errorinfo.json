ie\/google_rpc_errorinfo\/domain","kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/Yorkie\/documentation\/Yorkie\/Google_Rpc_ErrorInfo\/domain","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"domain"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"abstract":[{"text":"The logical grouping to which the “reason” belongs. The error domain","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is typically the registered service name of the tool or product that"},{"type":"text","text":" "},{"type":"text","text":"generates the error. Example: “pubsub.googleapis.com”. If the error is"},{"type":"text","text":" "},{"type":"text","text":"generated by some common infrastructure, the error domain must be a"},{"type":"text","text":" "},{"type":"text","text":"globally unique value that identifies the infrastructure. For Google API"},{"type":"text","text":" "},{"type":"text","text":"infrastructure, the error domain is “googleapis.com”."}],"title":"domain"},"doc://Yorkie/s28CustomDebugStringConvertibleP":{"title":"Swift.CustomDebugStringConvertible","type":"unresolvable","identifier":"doc:\/\/Yorkie\/s28CustomDebugStringConvertibleP"},"doc://Yorkie/documentation/Yorkie/Google_Rpc_ErrorInfo/reason":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reason","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"title":"reason","identifier":"doc:\/\/Yorkie\/documentation\/Yorkie\/Google_Rpc_ErrorInfo\/reason","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The reason of the error. This is a constant value that identifies the"},{"type":"text","text":" "},{"type":"text","text":"proximate cause of the error. Error reasons are unique within a particular"},{"type":"text","text":" "},{"type":"text","text":"domain of errors. This should be at most 63 characters and match a"},{"type":"text","text":" "},{"type":"text","text":"regular expression of "},{"type":"codeVoice","code":"[A-Z][A-Z0-9_]+[A-Z0-9]"},{"type":"text","text":", which represents"},{"type":"text","text":" "},{"type":"text","text":"UPPER_SNAKE_CASE."}],"kind":"symbol","url":"\/documentation\/yorkie\/google_rpc_errorinfo\/reason"}}}